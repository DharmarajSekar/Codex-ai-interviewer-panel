ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@postgres:5432/interviewer
REDIS_URL=redis://redis:6379/0
CHROMA_PERSIST_DIR=./.chroma
JWT_SECRET_KEY=replace-with-secure-secret
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
# Global
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# PostgreSQL
POSTGRES_DB=ai_interviewer
POSTGRES_USER=ai_user
POSTGRES_PASSWORD=ai_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ai_user:ai_password@postgres:5432/ai_interviewer

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=interview_knowledge

# LangChain / Providers (placeholder)
LLM_PROVIDER=openai
STT_PROVIDER=whisper
TTS_PROVIDER=elevenlabs
AVATAR_PROVIDER=d-id
